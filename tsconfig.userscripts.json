{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "alwaysStrict": false,
    "removeComments": false,
    "outFile": "userscripts/shuaforge-question-exporter.user.js"
  },
  "include": ["userscripts/src/**/*.ts"]
}
